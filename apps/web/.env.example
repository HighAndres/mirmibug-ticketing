DATABASE_URL="file:./dev.db"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
INTERNAL_API_KEY="your-secret-key-here"

# URL pública de la app (se usa en los links de los correos)
NEXTAUTH_URL="http://localhost:3000"

# Directorio raíz de la app, donde vive /public (subida de logos y adjuntos).
# En producción apuntar a la ruta absoluta de apps/web. Si se omite, se usa el CWD del proceso.
# APP_DIR="/ruta/a/apps/web"

# SMTP para notificaciones por correo.
# IMPORTANTE: sin SMTP_HOST los correos NO se envían (solo se registran en consola).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Mirmibug <notificaciones@mirmiapps.com>"
